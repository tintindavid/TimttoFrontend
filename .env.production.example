# Variables de entorno para producción
# Copia este archivo a .env.production y configura los valores reales

# URL del API Backend (OBLIGATORIO)
# Ejemplo: https://api.timtto.com/api/v1
VITE_API_URL=https://your-backend-api-url.com/api/v1

# Nombre de la aplicación
VITE_APP_NAME=Timtto - Mantenimiento Biomédico

# Otras configuraciones opcionales
# VITE_ENVIRONMENT=production
# VITE_ENABLE_ANALYTICS=true
